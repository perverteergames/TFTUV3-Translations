translate french ep023_lilly_second_talk_cfada94d_1:


    av "Félicitations !"


translate french ep023_lilly_second_talk_05a05dae_1:


    av "Tu vas être la meilleure mère qui soit !"


translate french ep023_lilly_second_talk_cb6344a6:


    l "C'est une super nouvelle, Aven !"


translate french ep023_lilly_second_talk_e79dfdd5:


    l "C'est génial !"


translate french ep023_lilly_second_talk_eb9dfe0f:


    av "Oui, c'est vrai !"


translate french ep023_lilly_second_talk_eac204d6:


    av "Félicitations à toi aussi !"


