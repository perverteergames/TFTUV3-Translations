#   c "I don’t think so."
    c "No lo creo."

# game/episode023_conversations.rpy:1461
translate spanish ep023_thyia_talk_9e5c3901:

#   th "Haha, me neither."
    th "Jaja, yo tampoco."

# game/episode023_conversations.rpy:1463
translate spanish ep023_thyia_talk_6a5d6d11:

#   th "So I guess we’ll shut him off for the duration."
    th "Así que supongo que lo apagaremos mientras dure."

# game/episode023_conversations.rpy:1464
translate spanish ep023_thyia_talk_c0e00c6b:

#   c "Can’t wait!"
    c "Estoy impaciente."

# game/episode023_conversations.rpy:1465
