translate spanish ep023_thyia_talk_ba9a06cf:

#   th "Intriguing."
    th "Intrigante."

# game/episode023_conversations.rpy:1444
translate spanish ep023_thyia_talk_7728df1f:

#   th "I’m game, whatever you do."
    th "Me apunto, hagas lo que hagas."

# game/episode023_conversations.rpy:1445
translate spanish ep023_thyia_talk_9faad7ec:

#   th "Though getting revenge sounds like a good plan to me."
    th "Aunque vengarse me parece un buen plan."

# game/episode023_conversations.rpy:1446
translate spanish ep023_thyia_talk_3d97e7d1:

#   c "I’ll keep you in the loop."
    c "Te mantendré informado."

# game/episode023_conversations.rpy:1449
translate spanish ep023_thyia_talk_da1cd697:

#   th "That would be great."
    th "Sería estupendo."

# game/episode023_conversations.rpy:1450
translate spanish ep023_thyia_talk_f63dea1b:

#   th "Though if you don’t have any news, you’re always welcome here."
    th "Aunque si no tienes noticias, siempre serás bienvenido aquí."

# game/episode023_conversations.rpy:1451
translate spanish ep023_thyia_talk_c5b79d95:

#   th "I’m sure we can find a way to pass the time."
    th "Seguro que encontramos la manera de pasar el tiempo."

# game/episode023_conversations.rpy:1452
translate spanish ep023_thyia_talk_31ee4375:

#   c "That sounds intriguing."
    c "Suena intrigante."

# game/episode023_conversations.rpy:1453
translate spanish ep023_thyia_talk_f7670755:

#   c "Will URGH provide running commentary though?"
    c "¿Pero URGH se encargará de los comentarios?"

# game/episode023_conversations.rpy:1455
translate spanish ep023_thyia_talk_e28a0e69:

#   th "If you want to."
    th "Si quieres."

# game/episode023_conversations.rpy:1457
translate spanish ep023_thyia_talk_4b3c6b5b:

#   th "It might enhance the mood?"
    th "¿Podría mejorar el estado de ánimo?"

# game/episode023_conversations.rpy:1458
translate spanish ep023_thyia_talk_04b2dc15:

#   c "“Please sir, I must insist you refrain from inserting that meaty protuberance into madam’s lubricated borehole.”"
    c "\"Por favor señor, debo insistir en que se abstenga de introducir esa protuberancia carnosa en el lubricado orificio de la señora\"."

# game/episode023_conversations.rpy:1459
