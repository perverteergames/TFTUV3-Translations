translate spanish ep023_thyia_talk_fcfce9bd:

#   c "Must have been them."
    c "Deben haber sido ellos."

# game/episode023_conversations.rpy:1431
translate spanish ep023_thyia_talk_8083d00e:

#   th "Yes, because a few hours later, the same ship on an outbound trajectory was registered by another probe."
    th "Sí, porque unas horas después, la misma nave en trayectoria de salida fue registrada por otra sonda."

# game/episode023_conversations.rpy:1433
translate spanish ep023_thyia_talk_57b9d20c:

#   th "I guess they took their time to scan the planet’s surface and came back empty-handed."
    th "Supongo que se tomaron su tiempo para escanear la superficie del planeta y volvieron con las manos vacías."

# game/episode023_conversations.rpy:1434
