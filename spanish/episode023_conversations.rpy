#   c "I wouldn’t want to be the captain of that ship."
    c "No me gustaría ser el capitán de ese barco."

# game/episode023_conversations.rpy:1436
translate spanish ep023_thyia_talk_3527b82e:

#   th "Me neither."
    th "Yo tampoco."

# game/episode023_conversations.rpy:1437
translate spanish ep023_thyia_talk_26bb7527:

#   th "I guess a few heads will have rolled by now."
    th "Supongo que ya habrán rodado algunas cabezas."

