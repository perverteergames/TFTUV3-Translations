translate spanish ep023_thyia_talk_34f52d73:

#   th "I was busy the first weeks, you might have heard."
    th "Las primeras semanas estuve ocupado, como habrás oído."

# game/episode023_conversations.rpy:1408
translate spanish ep023_thyia_talk_d54e1a01:

#   th "But after we all got back on the Bastard everything that happened really sank in."
    th "Pero después de que todos volvimos a la Bastard todo lo que pasó realmente se hundió."

# game/episode023_conversations.rpy:1409
translate spanish ep023_thyia_talk_e3a8ac5b:

#   c "Yeah, I can’t imagine what it’s been like for you these past few weeks."
    c "Sí, no puedo imaginar lo que ha sido para ti estas últimas semanas."

# game/episode023_conversations.rpy:1410
translate spanish ep023_thyia_talk_ca91f06b:

#   c "Lilly told me you managed to cleanse the entirety of Petrarch?"
    c "¿Lilly me dijo que lograste limpiar todo Petrarca?"

