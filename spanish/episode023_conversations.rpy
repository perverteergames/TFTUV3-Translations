translate spanish ep023_thyia_talk_9b6685c0:

#   c "Yes, I have."
    c "Sí, lo he hecho."

# game/episode023_conversations.rpy:1441
translate spanish ep023_thyia_talk_f70f80c1:

#   c "I’m going to bring the fight to the Sovereignty somehow."
    c "Voy a llevar la lucha a la Soberanía de alguna manera."

